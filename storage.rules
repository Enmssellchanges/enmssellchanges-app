rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'enmssellchanges@gmail.com';
    }

    // User receipts: Only owner or admin can read. Owner must set userId on write.
    match /receipts/{fileName} {
      allow read: if request.auth != null && (resource.metadata.userId == request.auth.uid || isAdmin());
      allow write: if request.auth != null && request.resource.metadata.userId == request.auth.uid;
    }
    
    // Admin proofs: The recipient user or admin can read.
    match /admin_proofs/{fileName} {
      allow read: if request.auth != null && (resource.metadata.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    // Rejections: The recipient user or admin can read.
    match /rejections/{fileName} {
      allow read: if request.auth != null && (resource.metadata.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Promos: Anyone can read, Admin can write.
    match /promos/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default rule: block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

